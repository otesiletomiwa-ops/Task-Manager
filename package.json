{
  "name": "task-manager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:api": "cd task-manager-api && npm run dev",
    "dev:frontend": "cd task-manager-frontend && npm run dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "install-all": "npm install --prefix task-manager-api && npm install --prefix task-manager-frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
